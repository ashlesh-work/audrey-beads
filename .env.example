# ---- Admin login (you choose these) ----
ADMIN_EMAIL=audrey@example.com
ADMIN_PASSWORD=change-this-to-something-strong

# ---- App ----
# Port the app listens on INSIDE the container (kept non-standard to avoid clashes).
PORT=8493
# Host port to publish (only if you use the optional ports mapping in docker-compose).
APP_PORT=8493
# Where the SQLite database + uploaded photos live (mounted as a volume).
DATA_DIR=/app/data

# Photo background cleanup: "imgly" (local AI; downloads a model once) or "off" (still enhances).
REMOVE_BG=imgly

# Cookie security: keep "true" when served over HTTPS (your reverse proxy / tunnel).
# Set to "false" ONLY for plain-http local testing, or the login cookie won't stick.
COOKIE_SECURE=true
